{
  "_doc": {
    "purpose": "Maps celebrity names to cutout PNG URLs used by CelebrityCard.tsx.",
    "schema": {
      "<slug>": {
        "display_name": "Human-readable name shown on screen",
        "cutout_url": "Cloudinary URL to a PNG with transparent background, or null",
        "context": "Optional 1-line context shown beneath the name (e.g. 'MUSICIAN, 2019' or '1955-2011')",
        "source_type": "public_domain | ai_generated | licensed | none",
        "channels": ["CH1", "CH2", "CH3", "CH4", "CH5"],
        "notes": "Free-form notes about sourcing or fair-use justification"
      }
    },
    "how_to_add_assets": [
      "1. Save your cutout PNG (transparent bg, ~2000px on long edge)",
      "2. Upload to Cloudinary at: dopamine-studios/celebrities/<slug>.png",
      "3. Copy the secure URL into the cutout_url field below",
      "4. The pipeline will auto-pick it up on the next run"
    ],
    "fallback_behavior": "If cutout_url is null, CelebrityCard renders a typographic-only frame with [ NAME ] in brackets. The video still plays; the visual is just less rich."
  },

